if(NOT DEFINED OBJECTS_FILE OR NOT DEFINED TEXT_FILE OR NOT DEFINED COLLISION_FILE OR NOT DEFINED OUTPUT)
  message(FATAL_ERROR "OBJECTS_FILE, TEXT_FILE, COLLISION_FILE, and OUTPUT must be provided")
endif()

file(STRINGS "${OBJECTS_FILE}" OBJECT_LINES)
file(STRINGS "${TEXT_FILE}" TEXT_LINES)
file(STRINGS "${COLLISION_FILE}" COLLISION_LINES)

set(PAGE_BREAK_MARKER "<PAGE_BREAK>")

function(escape_cpp out value)
  set(text "${value}")
  string(REPLACE "\\" "\\\\" text "${text}")
  string(REPLACE "\"" "\\\"" text "${text}")
  string(REPLACE "${PAGE_BREAK_MARKER}" "\\f" text "${text}")
  string(REPLACE "\n" "\\n" text "${text}")
  set(${out} "${text}" PARENT_SCOPE)
endfunction()

function(map_to_world_id out constant_name)
  if(constant_name STREQUAL "LAST_MAP")
    set(${out} "pokered::WorldId::RedsHouse1F" PARENT_SCOPE)
  elseif(constant_name STREQUAL "PEWTER_SPEECH_HOUSE")
    set(${out} "pokered::WorldId::PewterSpeechHouse" PARENT_SCOPE)
  else()
    message(FATAL_ERROR "Unsupported warp destination ${constant_name}")
  endif()
endfunction()

function(message_id_from_text out text_constant)
  if(text_constant STREQUAL "TEXT_PEWTERSPEECHHOUSE_GAMBLER")
    set(${out} "pokered::MessageId::PewterSpeechHouseGambler" PARENT_SCOPE)
  elseif(text_constant STREQUAL "TEXT_PEWTERSPEECHHOUSE_YOUNGSTER")
    set(${out} "pokered::MessageId::PewterSpeechHouseYoungster" PARENT_SCOPE)
  else()
    message(FATAL_ERROR "Unsupported text constant ${text_constant}")
  endif()
endfunction()

set(BORDER_BLOCK "0x00")
set(WARP_COUNT 0)
set(NPC_COUNT 0)
set(COLLISION_TILE_COUNT 0)
set(WARPS "")
set(NPCS "")
set(COLLISION_TILES "")

foreach(raw_line IN LISTS OBJECT_LINES)
  string(STRIP "${raw_line}" line)
  if(line MATCHES "^db \\$([0-9A-Fa-f]+)")
    string(TOUPPER "${CMAKE_MATCH_1}" border_hex)
    set(BORDER_BLOCK "0x${border_hex}")
  elseif(line MATCHES "^warp_event[ \t]+([0-9]+),[ \t]*([0-9]+),[ \t]*([A-Z0-9_]+),[ \t]*([0-9]+)")
    set(warp_destination "${CMAKE_MATCH_3}")
    if(warp_destination STREQUAL "LAST_MAP")
      set(uses_last_map "true")
    else()
      set(uses_last_map "false")
    endif()
    map_to_world_id(target_world_id "${warp_destination}")
    string(APPEND WARPS
           "    {${CMAKE_MATCH_1}, ${CMAKE_MATCH_2}, ${uses_last_map}, ${target_world_id}, ${CMAKE_MATCH_4}},\n")
    math(EXPR WARP_COUNT "${WARP_COUNT} + 1")
  elseif(line MATCHES "^object_event[ \t]+([0-9]+),[ \t]*([0-9]+),[ \t]*SPRITE_[A-Z0-9_]+,[ \t]*STAY,[ \t]*([A-Z]+),[ \t]*(TEXT_[A-Z0-9_]+)")
    set(facing_token "${CMAKE_MATCH_3}")
    if(facing_token STREQUAL "UP")
      set(facing "pokered::Facing::Up")
    elseif(facing_token STREQUAL "DOWN")
      set(facing "pokered::Facing::Down")
    elseif(facing_token STREQUAL "LEFT")
      set(facing "pokered::Facing::Left")
    elseif(facing_token STREQUAL "RIGHT")
      set(facing "pokered::Facing::Right")
    elseif(facing_token STREQUAL "NONE")
      set(facing "pokered::Facing::Down")
    else()
      message(FATAL_ERROR "Unsupported facing token: ${facing_token}")
    endif()
    message_id_from_text(message_id "${CMAKE_MATCH_4}")
    string(APPEND NPCS "    {${CMAKE_MATCH_1}, ${CMAKE_MATCH_2}, ${facing}, ${message_id}},\n")
    math(EXPR NPC_COUNT "${NPC_COUNT} + 1")
  endif()
endforeach()

set(IN_HOUSE_COLL FALSE)
foreach(raw_line IN LISTS COLLISION_LINES)
  string(STRIP "${raw_line}" line)
  if(line STREQUAL "House_Coll::")
    set(IN_HOUSE_COLL TRUE)
  elseif(IN_HOUSE_COLL AND line MATCHES "^coll_tiles")
    string(REGEX MATCHALL "\\$[0-9A-Fa-f][0-9A-Fa-f]" collision_matches "${line}")
    foreach(match IN LISTS collision_matches)
      string(SUBSTRING "${match}" 1 2 collision_hex)
      string(TOUPPER "${collision_hex}" collision_hex)
      string(APPEND COLLISION_TILES "    0x${collision_hex},\n")
      math(EXPR COLLISION_TILE_COUNT "${COLLISION_TILE_COUNT} + 1")
    endforeach()
    set(IN_HOUSE_COLL FALSE)
  endif()
endforeach()

if(COLLISION_TILE_COUNT EQUAL 0)
  message(FATAL_ERROR "Failed to parse House collision tiles from ${COLLISION_FILE}")
endif()

set(CURRENT_NAME "")
set(CURRENT_TEXT "")
set(MESSAGE_NAMES "")

foreach(raw_line IN LISTS TEXT_LINES)
  string(STRIP "${raw_line}" line)
  if(line MATCHES "^_([A-Za-z0-9_]+)::")
    set(CURRENT_NAME "${CMAKE_MATCH_1}")
    set(CURRENT_TEXT "")
  elseif(line MATCHES "^(text|line|cont|para) \"(.*)\"$")
    set(command_name "${CMAKE_MATCH_1}")
    set(chunk "${CMAKE_MATCH_2}")
    if(command_name STREQUAL "text")
      set(CURRENT_TEXT "${chunk}")
    elseif(command_name STREQUAL "para")
      string(APPEND CURRENT_TEXT "${PAGE_BREAK_MARKER}${chunk}")
    else()
      string(APPEND CURRENT_TEXT "\n${chunk}")
    endif()
  elseif(line STREQUAL "done" OR line STREQUAL "prompt")
    if(NOT CURRENT_NAME STREQUAL "")
      list(APPEND MESSAGE_NAMES "${CURRENT_NAME}")
      set("TEXT_${CURRENT_NAME}" "${CURRENT_TEXT}")
      set(CURRENT_NAME "")
      set(CURRENT_TEXT "")
    endif()
  endif()
endforeach()

file(WRITE "${OUTPUT}" "#pragma once\n\n#include <array>\n#include <cstdint>\n#include <string_view>\n\n#include \"pokered/world/map_data.hpp\"\n\nnamespace generated {\ninline constexpr std::uint8_t kPewterSpeechHouseBorderBlock = ${BORDER_BLOCK};\ninline constexpr std::array<pokered::Warp, ${WARP_COUNT}> kPewterSpeechHouseWarps = {{\n${WARPS}}};\ninline constexpr std::array<pokered::BgEvent, 0> kPewterSpeechHouseBgEvents = {};\ninline constexpr std::array<pokered::Npc, ${NPC_COUNT}> kPewterSpeechHouseNpcs = {{\n${NPCS}}};\ninline constexpr std::array<std::uint8_t, ${COLLISION_TILE_COUNT}> kHouseCollisionTiles = {{\n${COLLISION_TILES}}};\n")

foreach(message_name IN LISTS MESSAGE_NAMES)
  escape_cpp(escaped_text "${TEXT_${message_name}}")
  file(APPEND "${OUTPUT}" "inline constexpr std::string_view k${message_name} = \"${escaped_text}\";\n")
endforeach()

file(APPEND "${OUTPUT}" "}  // namespace generated\n")
